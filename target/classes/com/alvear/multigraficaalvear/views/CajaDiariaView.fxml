<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="25" styleClass="fondo-pestana" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.CajaDiariaController">
    <padding>
        <Insets bottom="30" left="40" right="40" top="30" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: black;" text="Cierre de Caja Diaria" />
    
    <HBox alignment="CENTER" spacing="10">
        <DatePicker fx:id="dpFechaInicio" prefWidth="150" promptText="Desde" />
        <DatePicker fx:id="dpFechaFin" prefWidth="150" promptText="Hasta" />
    </HBox>

    <Button onAction="#calcularCajaDesdeBoton" styleClass="btn-redondeado-gris" text="Calcular" />

    <HBox alignment="CENTER" maxWidth="800" spacing="20">
        <HBox alignment="CENTER_LEFT" prefHeight="120" spacing="20" styleClass="tarjeta-blanca" HBox.hgrow="ALWAYS">
            <ImageView fx:id="imgIconoVentas" fitHeight="60" fitWidth="60" />
            <VBox alignment="CENTER_LEFT" spacing="5">
                <Label style="-fx-font-size: 16px; -fx-text-fill: #333333;" text="Ventas Totales" />
                <Label fx:id="lblVentasTotales" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #8a2be2;" text="0.00" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" prefHeight="120" spacing="20" styleClass="tarjeta-blanca" HBox.hgrow="ALWAYS">
            <ImageView fx:id="imgIconoCobros" fitHeight="60" fitWidth="60" />
            <VBox alignment="CENTER_LEFT" spacing="5">
                <Label style="-fx-font-size: 16px; -fx-text-fill: #333333;" text="Total a Cobrar" />
                <Label fx:id="lblTotalACobrar" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0.00" /> 
            </VBox>
        </HBox>
    </HBox>

    <HBox alignment="CENTER" maxWidth="800" prefHeight="120" spacing="30" styleClass="tarjeta-blanca">
        <ImageView fx:id="imgIconoCaja" fitHeight="70" fitWidth="70" />
        <VBox alignment="CENTER" spacing="5">
            <Label style="-fx-font-size: 18px; -fx-text-fill: #333333;" text="Total Cobrado" />
            <Label fx:id="lblTotalCobrado" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0.00" /> 
        </VBox>
    </HBox>

    <Button onAction="#exportarPDF" styleClass="btn-redondeado-gris" text="📄 Exportar a PDF" />

</VBox>