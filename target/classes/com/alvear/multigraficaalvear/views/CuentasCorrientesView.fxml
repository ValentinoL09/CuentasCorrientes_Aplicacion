<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.CuentasCorrientesController">
    <children>
        <VBox spacing="15.0" AnchorPane.topAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.bottomAnchor="15.0">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            
            <Label text="Cuentas Corrientes" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <TableView fx:id="tblVentas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colIdVenta" text="ID Venta" prefWidth="80"/>
                    <TableColumn fx:id="colCliente" text="Cliente (ID)" prefWidth="120"/>
                    <TableColumn fx:id="colTotal" text="Total" prefWidth="120"/>
                    <TableColumn fx:id="colRecibido" text="Recibido" prefWidth="120"/>
                    <TableColumn fx:id="colSaldoPendiente" text="Saldo Pendiente" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Monto a Pagar:"/>
                <TextField fx:id="txtMontoPagar" promptText="Ingrese monto"/>
                <Button fx:id="btnRegistrarPago" text="Registrar Pago" style="-fx-font-size: 14px;" onAction="#registrarPago"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>
