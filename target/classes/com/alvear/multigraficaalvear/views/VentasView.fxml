<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.VentasController">
    <children>
        <VBox spacing="15.0" AnchorPane.topAnchor="15.0" AnchorPane.leftAnchor="15.0" AnchorPane.rightAnchor="15.0" AnchorPane.bottomAnchor="15.0">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            
            <Label text="Registro de Ventas" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Cliente"/>
                    <ComboBox fx:id="cmbCliente" promptText="Seleccione un cliente" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Tipo de Venta"/>
                    <ComboBox fx:id="cmbTipoVenta" promptText="Seleccione tipo de venta" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Descripcion"/>
                    <TextField fx:id="txtDescripcion" promptText="Ingrese descripcion del trabajo"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Monto Total"/>
                    <TextField fx:id="txtMontoTotal" promptText="Ingrese monto total"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Monto Recibido"/>
                    <TextField fx:id="txtMontoRecibido" promptText="Ingrese monto recibido"/>
                </VBox>
            </HBox>
            
            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Button fx:id="btnRegistrar" text="Registrar Venta" style="-fx-font-size: 14px; -fx-padding: 10px 20px;"/>
            </HBox>
            
            <TableView fx:id="tblVentas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colCliente" text="Cliente (ID)" prefWidth="150"/>
                    <TableColumn fx:id="colDescripcion" text="Descripcion" prefWidth="250"/>
                    <TableColumn fx:id="colMontoTotal" text="Total" prefWidth="120"/>
                    <TableColumn fx:id="colMontoRecibido" text="Recibido" prefWidth="120"/>
                    <TableColumn fx:id="colFecha" text="Fecha" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
        </VBox>
    </children>
</AnchorPane>
