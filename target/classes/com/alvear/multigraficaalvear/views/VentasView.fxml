<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.DatePicker?>

<VBox styleClass="fondo-pestana" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.VentasController" spacing="15.0">
    
    <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 10;">
        <Button fx:id="btnNavNuevaVenta" text="🛒 Nueva Venta" onAction="#mostrarNuevaVenta" styleClass="btn-form-primario" 
                minWidth="220.0" maxWidth="220.0" minHeight="45.0" maxHeight="45.0" 
                style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
        
        <Button fx:id="btnNavHistorial" text="📋 Historial de Ventas" onAction="#mostrarHistorial" styleClass="btn-form-secundario" 
                minWidth="220.0" maxWidth="220.0" minHeight="45.0" maxHeight="45.0" 
                style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
    </HBox>

    <StackPane VBox.vgrow="ALWAYS">
        
        <VBox fx:id="panelNuevaVenta" spacing="15.0" styleClass="panel-formulario">
            <Label styleClass="titulo-naranja" text="Registro de Venta" />
            
            <HBox spacing="15.0" alignment="CENTER_LEFT">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Cliente" style="-fx-text-fill: white;" />
                    <ComboBox fx:id="cmbCliente" promptText="Seleccione un cliente" maxWidth="Infinity" minHeight="40.0" prefHeight="40.0" styleClass="input-form" />
                </VBox>
            </HBox>
            
            <HBox spacing="10.0" alignment="BOTTOM_LEFT">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Servicio" style="-fx-text-fill: white;" />
                    <ComboBox fx:id="cmbServicios" promptText="Seleccione Servicio" maxWidth="Infinity" minHeight="40.0" prefHeight="40.0" styleClass="input-form"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Cant." style="-fx-text-fill: white;" />
                    <TextField fx:id="txtCantidad" promptText="0" prefWidth="70" minHeight="40.0" prefHeight="40.0" styleClass="input-form"/>
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Precio Unit." style="-fx-text-fill: white;" />
                    <TextField fx:id="txtPrecio" promptText="0.00" prefWidth="100" minHeight="40.0" prefHeight="40.0" styleClass="input-form"/>
                </VBox>
                <Button onAction="#agregarAlCarrito" text="Agregar" styleClass="btn-form-secundario" minHeight="40.0" prefHeight="40.0"/>
            </HBox>
            
            <TableView fx:id="tblCarrito" styleClass="tabla-oscura" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colServicio" text="Servicio" prefWidth="250"/>
                    <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="100"/>
                    <TableColumn fx:id="colPrecioUnitario" text="Precio Unit." prefWidth="120"/>
                    <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            
            <HBox spacing="15.0" alignment="CENTER_RIGHT">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Detalles de la venta" style="-fx-text-fill: white;" />
                    <TextField fx:id="txtDetalle" promptText="Observaciones opcionales..." prefHeight="38.0" styleClass="input-form" />
                </VBox>
                <VBox spacing="5.0">
                    <Label text="Monto Recibido" style="-fx-text-fill: white;" />
                    <TextField fx:id="txtMontoRecibido" promptText="0.00" prefWidth="120" prefHeight="38.0" styleClass="input-form" />
                </VBox>
                <VBox spacing="5.0" alignment="CENTER_RIGHT">
                    <Label fx:id="lblTotal" text="Total: $0.00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <HBox spacing="10.0">
                        <Button onAction="#limpiarFormulario" text="Limpiar" prefHeight="38.0" style="-fx-background-color: transparent; -fx-text-fill: #aaa; -fx-border-color: #555; -fx-border-radius: 5;"/>
                        <DatePicker fx:id="dpFechaVenta" promptText="Seleccionar fecha" styleClass="input-form" />
                        <Button onAction="#finalizarVenta" text="Finalizar Venta" prefHeight="38.0" styleClass="btn-form-primario"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

        <VBox fx:id="panelHistorial" spacing="15.0" styleClass="panel-formulario" visible="false" managed="false">
            <Label styleClass="titulo-naranja" text="Historial de Ventas (Seleccione una venta para ver sus artículos)" />
            
            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                <VBox HBox.hgrow="ALWAYS" spacing="5.0">
                    <Label text="Registro General" style="-fx-text-fill: white;"/>
                    <TableView fx:id="tblHistorial" styleClass="tabla-oscura" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colHistId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colHistFecha" text="Fecha" prefWidth="100"/>
                            <TableColumn fx:id="colHistCliente" text="Cliente" prefWidth="100"/>
                            <TableColumn fx:id="colHistTotal" text="Total ($)" prefWidth="100"/>
                            <TableColumn fx:id="colHistDetalle" text="Notas" prefWidth="150"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" spacing="5.0" prefWidth="350.0">
                    <Label text="Artículos Vendidos" style="-fx-text-fill: white;"/>
                    <TableView fx:id="tblDetalleHistorial" styleClass="tabla-oscura" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDetHistCant" text="Cant." prefWidth="50"/>
                            <TableColumn fx:id="colDetHistServicio" text="Producto" prefWidth="150"/>
                            <TableColumn fx:id="colDetHistPrecio" text="P. Unit" prefWidth="75"/>
                            <TableColumn fx:id="colDetHistSub" text="Subtotal" prefWidth="75"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </HBox>
        </VBox>

    </StackPane>
</VBox>