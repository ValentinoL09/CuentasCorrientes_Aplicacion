<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="fondo-pestana" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.ServiciosController">
    <VBox spacing="20.0" styleClass="panel-formulario" VBox.vgrow="ALWAYS">
        <children>
            
            <Label styleClass="titulo-naranja" text="Catalogo de Servicios" />

            <HBox spacing="15.0">
                <children>
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="label-form" text="Nombre del Servicio" />
                        <TextField fx:id="txtNombre" promptText="Nombre del Servicio" styleClass="input-form" />
                    </VBox>
                    
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="label-form" text="Categoria" />
                        <TextField fx:id="txtCategoria" promptText="Ej: Categoria" styleClass="input-form" />
                    </VBox>

                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label styleClass="label-form" text="Precio Sugerido" />
                        <TextField fx:id="txtPrecioSugerido" promptText="0.00" styleClass="input-form" />
                    </VBox>
                </children>
            </HBox>

            <HBox spacing="15.0">
                <children>
                    <Button fx:id="btnAgregar" onAction="#agregarServicio" styleClass="btn-form-primario" text="Agregar" prefWidth="100.0" />
                    <Button fx:id="btnActualizar" onAction="#actualizarServicio" styleClass="btn-form-secundario" text="Actualizar" prefWidth="100.0" />
                    <Button fx:id="btnEliminar" onAction="#eliminarServicio" styleClass="btn-form-peligro" text="Eliminar" prefWidth="100.0" />
                    <Button fx:id="btnLimpiar" onAction="#limpiarCampos" styleClass="btn-form-secundario" text="Limpiar" style="-fx-border-color: transparent; -fx-text-fill: white;" />
                </children>
            </HBox>

            <TableView fx:id="tblServicios" styleClass="tabla-oscura" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50.0" />
                    <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200.0" />
                    <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="150.0" />
                    <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100.0" />
                    <TableColumn text="Acciones" prefWidth="100.0" />
                </columns>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </TableView>

        </children>
    </VBox>
</VBox>