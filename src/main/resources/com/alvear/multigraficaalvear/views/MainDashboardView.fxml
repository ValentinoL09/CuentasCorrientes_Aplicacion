<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.MainDashboardController">
    <left>
        <VBox spacing="10.0" alignment="CENTER" prefWidth="200.0">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Button fx:id="btnServicios" text="Servicios" onAction="#mostrarServicios" maxWidth="Infinity"/>
            <Button fx:id="btnClientes" text="Clientes" onAction="#mostrarClientes" maxWidth="Infinity"/>
            <Button fx:id="btnVentas" text="Ventas" onAction="#mostrarVentas" maxWidth="Infinity"/>
            <Button fx:id="btnCuentasCorrientes" text="Cuentas Corrientes" onAction="#mostrarCuentasCorrientes" maxWidth="Infinity"/>
            <Button fx:id="btnCajaDiaria" text="Caja Diaria" onAction="#mostrarCajaDiaria" maxWidth="Infinity"/>
            <Button fx:id="btnCerrarSesion" text="Cerrar Sesion" onAction="#cerrarSesion" maxWidth="Infinity"/>
        </VBox>
    </left>
    <center>
        <BorderPane fx:id="contentArea" />
    </center>
</BorderPane>
