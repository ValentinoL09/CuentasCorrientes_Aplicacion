<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox styleClass="fondo-pestana" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.CuentasCorrientesController" spacing="15.0">
    
    <Label styleClass="titulo-naranja" text="Gestión de Cuentas Corrientes"/>
    
    <VBox styleClass="panel-formulario" VBox.vgrow="ALWAYS" spacing="15.0">
        
        <TableView fx:id="tblVentas" styleClass="tabla-oscura" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIdVenta" text="Nº Venta" prefWidth="80"/>
                <TableColumn fx:id="colCliente" text="Cliente" prefWidth="250"/> <TableColumn fx:id="colTotal" text="Total ($)" prefWidth="120"/>
                <TableColumn fx:id="colRecibido" text="Pagado ($)" prefWidth="120"/>
                <TableColumn fx:id="colSaldoPendiente" text="Saldo Pendiente ($)" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
        </TableView>
        
        <HBox spacing="15.0" alignment="CENTER_RIGHT">
            <Label text="Monto a Pagar:" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <TextField fx:id="txtMontoPagar" promptText="0.00" prefWidth="150" minHeight="40.0" prefHeight="40.0" styleClass="input-form"/>
            <Button fx:id="btnRegistrarPago" text="Registrar Pago" onAction="#registrarPago" minHeight="40.0" prefHeight="40.0" styleClass="btn-form-primario"/>
        </HBox>
        
    </VBox>
</VBox>