<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.LoginController" alignment="CENTER" spacing="15.0">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>
    
    <ImageView fx:id="imgLogo" fitHeight="150.0" fitWidth="150.0" preserveRatio="true">
        <image>
            <Image url="@../images/logo.jpg"/>
        </image>
    </ImageView>
    
    <TextField fx:id="txtUsuario" promptText="Usuario"/>
    <PasswordField fx:id="txtPassword" promptText="Contraseña"/>
    <Button fx:id="btnIngresar" text="Iniciar Sesion" onAction="#iniciarSesion" style="-fx-font-size: 14px;"/>
</VBox>
