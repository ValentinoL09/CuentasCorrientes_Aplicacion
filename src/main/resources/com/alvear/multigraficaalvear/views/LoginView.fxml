<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="25.0" styleClass="fondo-oscuro" stylesheets="@../css/styles.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>
    <children>
        
        <ImageView fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@../images/logo.jpg" />
            </image>
            <VBox.margin>
                <Insets bottom="15.0" />
            </VBox.margin>
        </ImageView>

        <HBox alignment="CENTER_LEFT" maxWidth="300.0" prefHeight="50.0" styleClass="caja-input">
            <children>
                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/usuarios.png" />
                    </image>
                    <effect>
                        <javafx.scene.effect.ColorAdjust brightness="1.0" />
                    </effect>
                    <HBox.margin>
                        <Insets left="15.0" right="10.0" />
                    </HBox.margin>
                </ImageView>
                <TextField fx:id="txtUsuario" promptText="Usuario" styleClass="input-transparente" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <HBox alignment="CENTER_LEFT" maxWidth="300.0" prefHeight="50.0" styleClass="caja-input">
            <children>
                <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/contrasena.png" />
                    </image>
                    <effect>
                        <javafx.scene.effect.ColorAdjust brightness="1.0" />
                    </effect>
                    <HBox.margin>
                        <Insets left="15.0" right="10.0" />
                    </HBox.margin>
                </ImageView>
                <PasswordField fx:id="txtPassword" promptText="Contraseña" styleClass="input-transparente" HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <Button maxWidth="300.0" onAction="#iniciarSesion" prefHeight="50.0" styleClass="btn-degradado" text="Iniciar Sesion">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>
        
    </children>
</VBox>