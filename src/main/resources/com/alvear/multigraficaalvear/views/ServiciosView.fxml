<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.ServiciosController" spacing="10.0">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    
    <Label text="Catalogo de Servicios" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Nombre"/>
            <TextField fx:id="txtNombre" promptText="Nombre del servicio"/>
        </VBox>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Categoria"/>
            <TextField fx:id="txtCategoria" promptText="Ej: Impresion, Diseño"/>
        </VBox>
        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Label text="Precio Sugerido"/>
            <TextField fx:id="txtPrecioSugerido" promptText="0.00"/>
        </VBox>
    </HBox>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Button fx:id="btnAgregar" text="Agregar" onAction="#agregarServicio"/>
        <Button fx:id="btnActualizar" text="Actualizar" onAction="#actualizarServicio"/>
        <Button fx:id="btnEliminar" text="Eliminar" onAction="#eliminarServicio"/>
        <Button fx:id="btnLimpiar" text="Limpiar" onAction="#limpiarCampos"/>
    </HBox>
    
    <TableView fx:id="tblServicios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
            <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="150"/>
            <TableColumn fx:id="colPrecio" text="Precio Sugerido" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
</VBox>
