<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <VBox spacing="10.0" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            
            <Label text="Gestion de Clientes" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            
            <HBox spacing="10.0">
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Nombre/Empresa"/>
                    <TextField fx:id="txtNombre" promptText="Ingrese nombre o empresa"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Telefono"/>
                    <TextField fx:id="txtTelefono" promptText="Ingrese telefono"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="CUIT"/>
                    <TextField fx:id="txtCuit" promptText="Ingrese CUIT"/>
                </VBox>
                <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label text="Correo Electronico"/>
                    <TextField fx:id="txtCorreo" promptText="Ingrese correo electronico"/>
                </VBox>
            </HBox>
            
            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Button fx:id="btnGuardar" text="Guardar"/>
                <Button fx:id="btnModificar" text="Modificar"/>
                <Button fx:id="btnEliminar" text="Eliminar"/>
            </HBox>
            
            <TableView fx:id="tblClientes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNombre" text="Nombre/Empresa" prefWidth="200"/>
                    <TableColumn fx:id="colTelefono" text="Telefono" prefWidth="150"/>
                    <TableColumn fx:id="colCuit" text="CUIT" prefWidth="150"/>
                    <TableColumn fx:id="colCorreo" text="Correo" prefWidth="200"/>
                </columns>
            </TableView>
        </VBox>
    </children>
</AnchorPane>
