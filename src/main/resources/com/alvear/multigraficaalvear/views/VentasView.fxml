<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alvear.multigraficaalvear.controllers.VentasController" spacing="15.0">
    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
    
    <Label text="Registro de Ventas" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <ComboBox fx:id="cmbCliente" promptText="Seleccione un cliente" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <ComboBox fx:id="cmbTipoVenta" promptText="Seleccione tipo de venta" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
    </HBox>
    
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <Label text="Producto:"/>
        <ComboBox fx:id="cmbServicios" promptText="Servicio" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
        <TextField fx:id="txtCantidad" promptText="Cant" prefWidth="80"/>
        <TextField fx:id="txtPrecio" promptText="Precio Unitario" prefWidth="120"/>
        <Button fx:id="btnAgregar" text="Agregar al Carrito" onAction="#agregarAlCarrito" style="-fx-font-size: 14px;"/>
    </HBox>
    
    <TableView fx:id="tblCarrito" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colServicio" text="Servicio" prefWidth="200"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="100"/>
            <TableColumn fx:id="colPrecioUnitario" text="Precio Unitario" prefWidth="150"/>
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="150"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>
    
    <VBox spacing="10.0" alignment="CENTER_RIGHT">
        <Label fx:id="lblTotal" text="Total: $0.0" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        <HBox spacing="10.0" alignment="CENTER_RIGHT">
            <Label text="Monto Recibido:"/>
            <TextField fx:id="txtMontoRecibido" promptText="0.00" prefWidth="120"/>
            <Button fx:id="btnFinalizar" text="Finalizar Venta" onAction="#finalizarVenta" style="-fx-font-size: 14px; -fx-padding: 10px 20px;"/>
        </HBox>
    </VBox>
</VBox>
